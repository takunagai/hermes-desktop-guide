<style>
  @layer hermes {
    .reuse-notice {
      max-width: var(--sl-content-width);
      margin: 2.5rem auto 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--sl-color-hairline);
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-xs);
      line-height: 1.7;
      text-align: center;
      text-wrap: pretty;
    }
