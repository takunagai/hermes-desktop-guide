---
import { getEntry } from "astro:content";

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
const versionReference = await getEntry("docs", "reference/version-evidence");
const hermesVersion = versionReference?.data.hermes_version;
---

<div class="site-identity">
  <a href={siteTitleHref} class="site-title sl-flex" aria-label={siteTitle}>
    <span class="site-name" translate="no">
      <span class="site-name-full">{siteTitle}</span>
      <span class="site-name-compact" aria-hidden="true">Hermes</span>
    </span>
  </a>

  {
    hermesVersion && (
      <a
        class="version-badge print:hidden"
        href="/reference/version-evidence/"
        aria-label={`このサイトの対応Hermes Desktopバージョンはv${hermesVersion}です。調査根拠を開く`}
      >
        <span class="version-label">対応</span>
        <span>v{hermesVersion}</span>
      </a>
    )
  }
</div>

<style>
  @layer starlight.core {
    .site-identity {
      display: flex;
      align-items: center;
      min-width: 0;
      gap: clamp(0.5rem, 1.2vw, 0.875rem);
    }

    .site-title {
      align-items: center;
      min-width: 0;
      gap: var(--sl-nav-gap);
      color: var(--sl-color-text-accent);
      font-size: var(--sl-text-h4);
      font-weight: 750;
      letter-spacing: -0.02em;
      text-decoration: none;
      white-space: nowrap;
    }

    .site-name {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .site-name-compact {
      display: none;
    }

    .version-badge {
      display: inline-flex;
      flex: none;
      align-items: center;
      gap: 0.4rem;
      border: 1px solid var(--sl-color-hairline-light);
      padding: 0.28rem 0.48rem;
      background: var(--sl-color-bg-nav);
      color: var(--sl-color-gray-2);
      font-family: var(--__sl-font-mono);
      font-size: 0.6875rem;
      font-weight: 650;
      letter-spacing: 0.04em;
      line-height: 1;
      text-decoration: none;
      white-space: nowrap;
    }

    .version-label {
      color: var(--sl-color-gray-3);
      font-family: var(--sl-font);
      font-size: 0.625rem;
      letter-spacing: 0;
    }

    .version-badge:hover {
      border-color: var(--sl-color-accent);
      background: var(--sl-color-accent-low);
      color: var(--sl-color-accent-high);
    }

    .version-badge:focus-visible {
      outline: 2px solid var(--sl-color-accent-high);
      outline-offset: 0.2rem;
    }

    @media (max-width: 34rem) {
      .site-name-full {
        display: none;
      }

      .site-name-compact {
        display: inline;
      }

      .version-label {
        display: none;
      }
    }
  }
</style>
