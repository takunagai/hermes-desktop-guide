---
// 「つまずいたら」ブロック。章末に置き、行き詰まったときの確認先を示す。
// スロットで個別の案内を渡せる。未指定なら汎用のトラブルシューティング導線を出す。
// Wave 4 で装飾を本実装するため、ここでは機能する最小実装に留める。
interface Props {
  title?: string;
}

const { title = "つまずいたら" } = Astro.props;
---

<aside class="tutorial-stumble" aria-label={title}>
  <p class="stumble-title">{title}</p>
  <div class="stumble-body">
    <slot>
      <p>
        うまく動かないときは、まず
        <a href="/troubleshooting/first-response/">問題の切り分け</a>
        を確認してください。検索バーからエラー文や設定名で探すのも有効です。
      </p>
    </slot>
  </div>
</aside>

<style>
  .tutorial-stumble {
    margin-block: 2rem 0;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .stumble-title {
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .stumble-body :global(p) {
    margin: 0;
    font-size: var(--sl-text-sm);
  }
</style>
