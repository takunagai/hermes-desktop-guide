---
// 概念解説（tutorials コレクションの concepts/* ）の動的ルート。
// Starlight 標準シェルで描画する。トーンは「親しみを保ちつつ実用（splash 寄り）」で、
// learn ほど装飾せず、構造図を中央寄せの枠で見せることを主役にする。
import { getCollection, render } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

export async function getStaticPaths() {
  const entries = await getCollection("tutorials", (entry) =>
    entry.data.slug.startsWith("concepts/"),
  );
  return entries.map((entry) => ({
    params: { slug: entry.data.slug.replace(/^concepts\//, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { title, description, slug } = entry.data;

const frontmatter = {
  title,
  description,
  slug,
  editUrl: false as const,
};
---

<StarlightPage frontmatter={frontmatter} headings={headings}>
  <div class="concepts-article">
    <Content />
  </div>
</StarlightPage>

<style>
  /* 概念解説のトーン（splash 寄り）。concepts-article 配下にのみ適用し、
     learn / reference には影響させない。starlight.css は触らない。 */

  /* 構造図（/diagrams/*.svg）を中央寄せ・最大幅・薄い枠で「図」として見せる。
     本文幅いっぱいに広がって大きくなりすぎるのを防ぎ、落ち着いた実用トーンにする。 */
  .concepts-article :global(img[src^="/diagrams/"]) {
    display: block;
    width: 100%;
    max-width: 580px;
    margin-inline: auto;
    margin-block: 1.75rem;
    padding: clamp(0.85rem, 2.5vw, 1.4rem);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--sl-color-accent) 4%, var(--sl-color-bg));
  }
</style>
