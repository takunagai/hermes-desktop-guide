---
interface Props {
  title: string;
  headings?: { depth: number; slug: string; text: string }[];
  currentSlug?: string;
  frontmatter?: Record<string, unknown>;
}

import { getCollection } from "astro:content";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

const { title, headings = [], currentSlug = "", frontmatter = {} } = Astro.props;

// コレクションからすべてのドキュメントを取得してサイドバー用に整理
const allDocs = await getCollection("docs");

// ホーム (index) を除くグループ分け
const groupsMap = new Map<
  string,
  {
    key: string;
    displayName: string;
    items: { slug: string; url: string; title: string; order: number }[];
  }
>();

for (const doc of allDocs) {
  if (doc.id === "index") continue;

  const parts = doc.id.split("/");
  if (parts.length > 1) {
    const groupKey = parts[0];
    const displayName = groupKey.replace(/^\d+[\s_]+/, "");

    let group = groupsMap.get(groupKey);
    if (!group) {
      group = {
        key: groupKey,
        displayName,
        items: [],
      };
      groupsMap.set(groupKey, group);
    }

    const cleanTitle = doc.data.title.replace(/^\d+[\s_]+/, "");
    group.items.push({
      slug: doc.id,
      url: `/${doc.id}`,
      title: cleanTitle,
      order: doc.data.order || 0,
    });
  } else {
    const cleanTitle = doc.data.title.replace(/^\d+[\s_]+/, "");
    let group = groupsMap.get("other");
    if (!group) {
      group = {
        key: "other",
        displayName: "その他",
        items: [],
      };
      groupsMap.set("other", group);
    }
    group.items.push({
      slug: doc.id,
      url: `/${doc.id}`,
      title: cleanTitle,
      order: doc.data.order || 0,
    });
  }
}

const sortedGroups = Array.from(groupsMap.values()).sort((a, b) => a.key.localeCompare(b.key));

for (const group of sortedGroups) {
  group.items.sort((a, b) => {
    if (a.order !== b.order) {
      return a.order - b.order;
    }
    return a.slug.localeCompare(b.slug);
  });
}

const homeItem = {
  url: "/",
  title: "ホーム",
  slug: "index",
};

// TOCのフィルタリング (h2, h3 のみを表示)
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

// バージョン情報
const verifiedDate = frontmatter.verified ? String(frontmatter.verified) : undefined;
const hermesVersion = frontmatter.hermes_version || undefined;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Hermes Desktop 設定ガイド</title>
    <ClientRouter />
    
    <!-- ダークモード初期化スクリプト -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
    </script>
  </head>
  <body class="bg-slate-50 text-slate-800 dark:bg-slate-950 dark:text-slate-200 transition-colors duration-200">
    <!-- ヘッダー -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-200/80 dark:border-slate-800/80 bg-white/70 dark:bg-slate-900/70 backdrop-blur-md transition-colors">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <!-- モバイル用サイドバー開閉ボタン -->
          <button id="mobile-menu-toggle" class="p-2 -ml-2 md:hidden text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors" aria-label="メニューを開く">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          
          <a href="/" class="flex items-center gap-2 font-bold text-lg md:text-xl tracking-tight bg-gradient-to-r from-blue-600 to-indigo-500 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent">
            Hermes Desktop 設定ガイド
          </a>
          {hermesVersion && (
            <span class="hidden sm:inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100/80 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300">
              v{hermesVersion}
            </span>
          )}
        </div>

        <div class="flex items-center gap-4">
          <!-- クライアント検索窓 (後述のReactコンポーネント用プレースホルダー、今回はシンプル版をHTMLで実装) -->
          <div class="relative hidden sm:block w-48 md:w-64">
            <input 
              type="text" 
              id="search-input" 
              placeholder="検索..." 
              class="w-full text-sm px-3 py-1.5 pl-8 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-100/50 dark:bg-slate-900/50 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all"
            />
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-2.5 top-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <!-- 簡易的な検索結果コンテナ -->
            <div id="search-results" class="hidden absolute top-full right-0 w-80 mt-1 max-h-96 overflow-y-auto rounded-lg shadow-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-2 z-50"></div>
          </div>

          <!-- テーマ切り替えトグル -->
          <button id="theme-toggle" class="p-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all duration-200" aria-label="テーマの切り替え">
            <!-- 太陽アイコン (ダークモードで表示) -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden dark:block text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m2.828 0l-.707-.707m2.828-10.828l-.707-.707M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <!-- 月アイコン (ライトモードで表示) -->
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 block dark:hidden text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- メイン領域 -->
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 flex">
      
      <!-- サイドバー (デスクトップ: 260px, モバイル: ドロワー) -->
      <aside id="sidebar" class="fixed inset-y-0 left-0 z-30 w-[270px] transform -translate-x-full md:translate-x-0 md:sticky md:top-16 md:h-[calc(100vh-4rem)] md:shrink-0 border-r border-slate-200/80 dark:border-slate-800/80 bg-white dark:bg-slate-950 md:bg-transparent transition-all duration-300 overflow-y-auto py-6 md:py-8 pr-4 pl-4 md:pl-0">
        <nav class="space-y-6">
          <div>
            <a href={homeItem.url} class={`flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-colors ${currentSlug === homeItem.slug || currentSlug === '' ? 'bg-blue-50 text-blue-600 dark:bg-blue-950/40 dark:text-blue-400 font-semibold' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100/50 dark:hover:bg-slate-900/50'}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              {homeItem.title}
            </a>
          </div>

          {sortedGroups.map((group) => (
            <div class="space-y-1.5" key={group.key}>
              <h3 class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 font-display">
                {group.displayName}
              </h3>
              <ul class="space-y-1">
                {group.items.map((item: any) => (
                  <li key={item.slug}>
                    <a
                      href={item.url}
                      class={`block px-3 py-1.5 text-sm rounded-lg transition-all ${
                        currentSlug === item.slug
                          ? 'bg-blue-50 text-blue-600 dark:bg-blue-950/40 dark:text-blue-400 font-semibold border-l-2 border-blue-500 rounded-l-none'
                          : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100/50 dark:hover:bg-slate-900/50'
                      }`}
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- オーバーレイ (モバイルサイドバー表示時の背景) -->
      <div id="sidebar-overlay" class="fixed inset-0 z-20 bg-slate-900/30 backdrop-blur-sm hidden md:hidden"></div>

      <!-- メインコンテンツ -->
      <main class="flex-1 min-w-0 max-w-4xl mx-auto py-8 md:py-12 px-0 md:px-8 lg:px-12">
        <article class="markdown-body">
          {verifiedDate && (
            <div class="mb-6 flex flex-wrap items-center gap-2 text-xs text-slate-400 dark:text-slate-500 border-b border-slate-100 dark:border-slate-900 pb-4">
              <span class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                実機確認日: {verifiedDate}
              </span>
              {frontmatter.hermes_commit && (
                <span class="flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  コミット: <code class="ml-1 px-1 py-0 bg-slate-100 dark:bg-slate-800 rounded font-mono text-[10px]">{frontmatter.hermes_commit}</code>
                </span>
              )}
            </div>
          )}
          <slot />
        </article>
      </main>

      <!-- 右側: 目次 (TOC) (デスクトップのみ) -->
      {tocItems.length > 0 && (
        <aside class="hidden lg:block w-[240px] shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto py-8 pl-6">
          <div class="space-y-3">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 font-display">
              目次
            </h3>
            <ul class="space-y-2 text-sm">
              {tocItems.map((item) => (
                <li 
                  class={`${item.depth === 3 ? 'pl-3' : ''}`}
                  key={item.slug}
                >
                  <a 
                    href={`#${item.slug}`} 
                    class="text-slate-500 dark:text-slate-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors block leading-snug py-0.5 toc-link"
                    data-slug={item.slug}
                  >
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}
    </div>

    <!-- テーマ切り替え & モバイルメニュー制御スクリプト -->
    <script>
      const setupLayout = () => {
        // テーマ切り替え
        const themeToggle = document.getElementById('theme-toggle');
        themeToggle?.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
        });

        // モバイルサイドバーのトグル
        const mobileToggle = document.getElementById('mobile-menu-toggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');

        const toggleSidebar = () => {
          const isOpen = sidebar?.classList.toggle('translate-x-0');
          sidebar?.classList.toggle('-translate-x-full');
          overlay?.classList.toggle('hidden');
          document.body.classList.toggle('overflow-hidden', isOpen);
        };

        mobileToggle?.addEventListener('click', toggleSidebar);
        overlay?.addEventListener('click', toggleSidebar);

        // クライアント側簡易検索の実装
        const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
        const searchResults = document.getElementById('search-results');

        if (searchInput && searchResults) {
          // Astro 側でビルドしたコレクションのJSON風データをメモリに取得
          // 今回はシンプルに、ページタイトルのマッチングを行います
          const docsData: { title: string; url: string; category: string }[] = [];
          
          // サイドバーから全記事のリストを動的にパースして辞書を作る
          document.querySelectorAll('aside#sidebar nav ul li a').forEach((el) => {
            const anchor = el as HTMLAnchorElement;
            const categoryEl = anchor.closest('div')?.querySelector('h3');
            docsData.push({
              title: anchor.textContent?.trim() || '',
              url: anchor.getAttribute('href') || '',
              category: categoryEl?.textContent?.trim() || 'その他'
            });
          });

          searchInput.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
            if (!query) {
              searchResults.classList.add('hidden');
              return;
            }

            const matches = docsData.filter(doc => 
              doc.title.toLowerCase().includes(query) || 
              doc.category.toLowerCase().includes(query)
            );

            if (matches.length === 0) {
              searchResults.innerHTML = '<div class="text-xs p-3 text-slate-400">見つかりませんでした</div>';
            } else {
              searchResults.innerHTML = matches.map(doc => `
                <a href="${doc.url}" class="block p-2 rounded hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <div class="text-xs font-semibold text-blue-500 dark:text-blue-400">${doc.category}</div>
                  <div class="text-sm font-medium text-slate-800 dark:text-slate-200">${doc.title}</div>
                </a>
              `).join('');
            }
            searchResults.classList.remove('hidden');
          });

          // 枠外クリックで検索窓を閉じる
          document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node)) {
              searchResults.classList.add('hidden');
            }
          });
        }

        // TOC Active Link Highlighter (IntersectionObserver)
        const tocLinks = document.querySelectorAll('.toc-link');
        const headings = document.querySelectorAll('.markdown-body h2, .markdown-body h3');

        if (tocLinks.length > 0 && headings.length > 0) {
          const observerOptions = {
            root: null,
            rootMargin: '-80px 0px -80% 0px',
            threshold: 0
          };

          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const activeId = entry.target.getAttribute('id');
                tocLinks.forEach(link => {
                  const href = link.getAttribute('href');
                  if (href === `#${activeId}`) {
                    link.classList.add('text-blue-500', 'dark:text-blue-400', 'font-semibold');
                    link.classList.remove('text-slate-500', 'dark:text-slate-400');
                  } else {
                    link.classList.remove('text-blue-500', 'dark:text-blue-400', 'font-semibold');
                    link.classList.add('text-slate-500', 'dark:text-slate-400');
                  }
                });
              }
            });
          }, observerOptions);

          headings.forEach(heading => observer.observe(heading));
        }
      };

      // ページ読み込み時および遷移完了時に初期化
      setupLayout();
      document.addEventListener('astro:after-swap', setupLayout);
    </script>
  </body>
</html>
