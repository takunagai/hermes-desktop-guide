{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hermes-desktop-guide",
  "compatibility_date": "2026-06-10",
  // 公開はカスタムドメイン hermes.ai-deck.app に一本化。
  // workers.dev URL は無効化済み（戻す場合は true）。
  "workers_dev": false,
  "preview_urls": true,
  "routes": [{ "pattern": "hermes.ai-deck.app", "custom_domain": true }],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
