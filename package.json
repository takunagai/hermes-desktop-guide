{
  "name": "hermes-desktop-guide",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "preprocess": "tsx scripts/preprocess.ts",
    "migrate:vault": "tsx scripts/migrate-vault-ia.ts",
    "validate:content": "npm run preprocess && npm test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "astro check",
    "test": "node --import tsx --test scripts/tests/*.test.ts",
    "check:links": "tsx scripts/check-built-links.ts",
    "quality": "npm run lint && npm run check && npm test && npm run build && npm run check:links"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.39.3",
    "astro": "^6.4.4",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "linkedom": "^0.18.12",
    "tsx": "^4.19.2"
  },
  "overrides": {
    "yaml": "^2.8.3"
  }
}
