{
  "name": "hermes-desktop-guide",
  "type": "module",
  "version": "0.0.1",
  "description": "Hermes Desktop（Nous Research 製デスクトップ AI エージェント）の非公式日本語ガイド。Obsidian Vault を正本に Astro Starlight で静的サイト化する。",
  "author": "Taku Nagai (ながたく)",
  "license": "CC-BY-4.0 AND MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/takunagai/hermes-desktop-guide.git"
  },
  "homepage": "https://github.com/takunagai/hermes-desktop-guide#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "preprocess": "tsx scripts/preprocess.ts",
    "migrate:vault": "tsx scripts/migrate-vault-ia.ts",
    "validate:content": "npm run preprocess && npm test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "astro check",
    "test": "node --import tsx --test scripts/tests/*.test.ts",
    "check:links": "tsx scripts/check-built-links.ts",
    "quality": "npm run lint && npm run check && npm test && npm run build && npm run check:links",
    "deploy": "astro build && wrangler deploy",
    "cf:preview": "astro build && wrangler dev"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.39.3",
    "astro": "^6.4.4",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/js-yaml": "^4.0.9",
    "linkedom": "^0.18.12",
    "tsx": "^4.19.2",
    "wrangler": "^4.99.0"
  },
  "overrides": {
    "vite": "^7.3.5",
    "yaml": "^2.8.3"
  }
}
